{
  "type": "message",
  "attachments": [
    {
      "contentType": "application/vnd.microsoft.card.adaptive",
      "content": {
        "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
        "type": "AdaptiveCard",
        "version": "1.2",
        "body": [
          {
            "type": "TextBlock",
            "size": "Large",
            "weight": "Bolder",
            "text": "🧰 New Image Published"
          },
          {
            "type": "TextBlock",
            "text": "**Image:** {{IMAGE_NAME}}",
            "wrap": true
          },
          {
            "type": "TextBlock",
            "text": "**Version:** {{VERSION}}",
            "wrap": true
          },
          {
            "type": "TextBlock",
            "text": "**Triggered by:** {{PIPELINE_SOURCE}}",
            "wrap": true
          },
          {
            "type": "TextBlock",
            "text": "[View pipeline]({{PIPELINE_URL}})",
            "wrap": true
          }
        ]
      }
    }
  ]
}
